{
  "name": "@oxia-db/client",
  "version": "0.1.0",
  "description": "Oxia client SDK for Node.js",
  "license": "Apache-2.0",
  "author": "The Oxia Authors",
  "homepage": "https://oxia-db.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxia-db/oxia-client-node.git"
  },
  "bugs": {
    "url": "https://github.com/oxia-db/oxia-client-node/issues"
  },
  "keywords": [
    "oxia",
    "oxia-db",
    "kv",
    "key-value",
    "metadata",
    "coordination",
    "distributed",
    "grpc",
    "notifications"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "proto",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen-proto": "bash gen-proto.sh",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "docs": "typedoc",
    "prepublishOnly": "npm run gen-proto && npm run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0",
    "@grpc/grpc-js": "^1.12.0",
    "@node-rs/xxhash": "^1.7.6",
    "long": "^5.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^24.0.0",
    "testcontainers": "^11.0.0",
    "ts-proto": "^2.2.0",
    "typedoc": "^0.28.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
